# Rotate BOT_TOKEN before production
BOT_TOKEN=
CHANNEL_ID=
LOG_CHANNEL_ID=

# Public URL where users open /verify (e.g. https://your-app.railway.app)
PUBLIC_BASE_URL=http://localhost:8000

FINGERPRINT_PUBLIC_KEY=
FINGERPRINT_SECRET_KEY=

DATABASE_URL=postgresql+asyncpg://singulr:singulr@localhost:5432/singulr
# For local dev without Docker: sqlite+aiosqlite:///./singulr.db

CHAIN_RPC=https://rpc.telcoin.network
CHAIN_ID=2017
CHAIN_EXPLORER=https://telscan.io
CONTRACT_ADDRESS=
WALLET_PRIVATE_KEY=
CHAIN_AUTHORIZED_SIGNER=

TOKEN_EXPIRY_MINUTES=10
WATCHER_INTERVAL_MINUTES=60
KEYSTROKE_SIMILARITY_THRESHOLD=0.85
STYLOMETRY_SIMILARITY_THRESHOLD=0.80

# Optional ops settings (overnight-ops)
ADMIN_API_KEY=
LOG_JSON=false
VERIFY_RATE_LIMIT_PER_MINUTE=30

# Social profiling (optional — Telegram heuristics always on when channel profiling enabled)
# Self-hosted JSON blocklist: copy data/social_blocklist.example.json and set path
SOCIAL_BLOCKLIST_PATH=
# External HTTP API (opt-in per channel via /security wizard)
SOCIAL_API_URL=
SOCIAL_API_KEY=
SOCIAL_API_TIMEOUT_SECONDS=1.5
# Test-only mock provider extras (SOCIAL_PROFILE_PROVIDER=mock)
SOCIAL_PROFILE_PROVIDER=none
MOCK_SOCIAL_HARD_USER_IDS=
MOCK_SOCIAL_SOFT_USER_IDS=
